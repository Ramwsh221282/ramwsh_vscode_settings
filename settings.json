{
  // general
  "explorer.confirmDelete": false,
  "security.workspace.trust.enabled": false,
  "explorer.compactFolders": true,

  // appearence:
  "editor.minimap.enabled": false,
  "window.zoomLevel": 1.5,
  "editor.cursorStyle": "block",
  "editor.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.codeLensFontFamily": "JetBrainsMono Nerd Font Mono",
  "chat.fontFamily": "JetBrainsMono Nerd Font Mono",
  "scm.inputFontFamily": "JetBrainsMono Nerd Font Mono",
  "errorLens.fontFamily": "JetBrainsMono Nerd Font Mono",
  "chat.editor.fontFamily": "JetBrainsMono Nerd Font Mono",
  "debug.console.fontFamily": "JetBrainsMono Nerd Font Mono",
  "notebook.output.fontFamily": "JetBrainsMono Nerd Font Mono",
  "gitlens.blame.fontFamily": "JetBrainsMono Nerd Font Mono",
  "notebook.markup.fontFamily": "JetBrainsMono Nerd Font Mono",
  "markdown.preview.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.inlayHints.fontFamily": "JetBrainsMono Nerd Font Mono",
  "gitlens.currentLine.fontFamily": "JetBrainsMono Nerd Font Mono",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.inlineSuggest.fontFamily": "JetBrainsMono Nerd Font Mono",
  "workbench.experimental.fontFamily": "JetBrainsMono Nerd Font Mono",
  "workbench.tabs.experimental.fontFamily": "JetBrainsMono Nerd Font Mono",
  "workbench.sideBar.experimental.fontFamily": "JetBrainsMono Nerd Font Mono",
  "workbench.statusBar.experimental.fontFamily": "JetBrainsMono Nerd Font Mono",
  "workbench.bottomPane.experimental.fontFamily": "JetBrainsMono Nerd Font Mono",
  "workbench.activityBar.experimental.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.fontWeight": "600",

  // zen:
  "zenMode.centerLayout": false,
  "zenMode.fullScreen": true,
  "zenMode.hideActivityBar": false,
  "zenMode.hideLineNumbers": false,
  "zenMode.hideStatusBar": false,
  "zenMode.restore": true,
  "zenMode.showTabs": "multiple",
  "zenMode.silentNotifications": false,

  // debugging:
  "debug.inlineValues": "on",

  // suggestions:
  "editor.inlineSuggest.edits.showLongDistanceHint": true,
  "editor.suggest.showFolders": true,
  "editor.suggest.showWords": true,
  "editor.suggest.showClasses": true,
  "editor.suggest.showColors": true,
  "editor.suggest.showConstants": true,
  "editor.suggest.showConstructors": true,
  "editor.suggest.showCustomcolors": true,
  "editor.suggest.showDeprecated": true,
  "editor.suggest.showEnumMembers": true,
  "editor.suggest.showEnums": true,
  "editor.suggest.showEvents": true,
  "editor.suggest.showFields": true,
  "editor.suggest.showFiles": true,
  "editor.suggest.showFunctions": true,
  "editor.suggest.showIcons": true,
  "editor.suggest.showInlineDetails": true,
  "editor.suggest.showInterfaces": true,
  "editor.suggest.showKeywords": true,
  "editor.suggest.showIssues": true,
  "editor.suggest.showMethods": true,
  "editor.suggest.showModules": true,
  "editor.suggest.showOperators": true,
  "editor.suggest.showProperties": true,
  "editor.suggest.showReferences": true,
  "editor.suggest.showSnippets": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.showStructs": true,
  "editor.suggest.showTypeParameters": true,
  "editor.suggest.showUnits": true,
  "editor.suggest.showUsers": true,
  "editor.suggest.showValues": true,
  "editor.suggest.showVariables": true,
  "editor.inlineSuggest.showToolbar": "never",
  "editor.quickSuggestionsDelay": 0,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": "on",
  },
  "editor.suggest.matchOnWordStartOnly": true,
  "editor.suggest.filterGraceful": true,
  "editor.suggest.localityBonus": true,
  "editor.inlineSuggest.edits.allowCodeShifting": "horizontal",
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.minShowDelay": 0,
  "editor.wordBasedSuggestions": "allDocuments",
  "editor.inlineCompletionsAccessibilityVerbose": true,
  "editor.inlineSuggest.edits.renderSideBySide": "auto",
  "editor.inlineSuggest.edits.showCollapsed": true,
  "editor.screenReaderAnnounceInlineSuggestion": true,
  "editor.suggest.preview": true,

  // formatting:
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,

  // tailwindcss:
  "tailwindCSS.includeLanguages": {
    "*.css": "tailwindcss",
    "*.vue": "tailwindcss",
    "*.ts": "tailwindcss",
  },

  // git
  "git.openRepositoryInParentFolders": "always",

  // errorLens:
  "errorLens.border": ["2px solid", "2px solid", "2px solid", "2px solid"],
  "errorLens.codeLensEnabled": false,
  "errorLens.enabledDiagnosticLevels": ["error", "warning", "info", "hint"],
  "errorLens.padding": "2px 1ch",
  "errorLens.gutterIconsEnabled": true,
  "errorLens.messageBackgroundMode": "none",
  "chat.disableAIFeatures": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",

  // telemetry:
  "telemetry.editStats.details.enabled": false,
  "telemetry.editStats.enabled": false,
  "telemetry.editStats.showDecorations": false,
  "telemetry.editStats.showStatusBar": false,
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "gitlens.telemetry.enabled": false,
  "editor.experimental.treeSitterTelemetry": false,

  // vue:
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar",
    "editor.formatOnSave": true,
  },

  // css
  "css.enabledLanguages": [
    "html",
    "ts",
    "typescript",
    "javascript",
    "javascriptreact",
    "typescriptreact",
    "vue",
    "css",
    "scss",
    "less",
    "postcss",
    "sass",
  ],
  "css.hover.documentation": true,
  "css.styleSheets": ["src/**/*.css", "**/*.css"],

  "workbench.colorTheme": "Calmppuccin Mocha",
  "calmppuccin.profiles": {
    "Default": {
      "fontStyleOverrides": {
        "mocha": {
          "commentFontStyle": "none",
          "typeFontStyle": "none",
          "typeAliasFontStyle": "none",
          "namespaceAttributeFontStyle": "none",
          "annotationFontStyle": "none",
          "directiveFontStyle": "none",
          "decoratorFontStyle": "none",
          "enumMemberFontStyle": "none",
          "propertyReadOnlyFontStyle": "none",
          "variableMutableFontStyle": "none",
          "extensionMethodFontStyle": "none",
          "delegateFontStyle": "none",
          "eventFontStyle": "none",
          "parameterFontStyle": "none",
        },
      },
    },
  },
  "workbench.iconTheme": "catppuccin-mocha",

  "github.copilot.nextEditSuggestions.eagerness": "high",
  "github.copilot.nextEditSuggestions.allowWhitespaceOnlyChanges": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.extendedRange": true,
  "github.copilot.nextEditSuggestions.fixes": true,
}
