{
  "git.openRepositoryInParentFolders": "always",
  "window.zoomLevel": 2,
  "editor.cursorStyle": "block",

  // debugging:
  "debug.inlineValues": "on",

  // suggestions settings
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontWeight": "600",
  "editor.suggest.showFolders": true,
  "editor.suggest.showWords": true,
  "editor.suggest.preview": true,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": "on"
  },

  // "editor.inlineSuggest.showToolbar": "always",
  // css html settings:
  "css.enabledLanguages": ["html", "vue", "typescript", "ts"],
  "css.styleSheets": ["src/**/*.css"],

  // tailwind css settings:
  "tailwindCSS.includeLanguages": {
    "*.css": "tailwindcss",
    "*.vue": "tailwindcss",
    "*.ts": "tailwindcss"
  },

  // formatting:
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar"
  },

  // errors showing in editor:
  "statusbarerror.gutter.hint.show": true,
  "statusbarerror.gutter.info.show": true,
  "statusbarerror.gutter.warning.show": true,
  "statusbarerror.gutter.error.show": true,
  "statusbarerror.wholeLine.show": true,
  "statusbarerror.color.warning": "#dfcb9e",
  "statusbarerror.color.error": "#e98ea8",
  "statusbarerror.color.hint": "#addaa8",
  "statusbarerror.color.info": "#8eb2eb",
  "statusbarerror.wholeLine.warningColor": "#dfcb9e",
  "statusbarerror.wholeLine.errorColor": "#e98ea8",
  "statusbarerror.wholeLine.errorFontColor": "#11111b",
  "statusbarerror.wholeLine.warningFontColor": "#11111b",

  // custom css and js:
  "vscode_custom_css.imports": [
    "file://${userHome}/.vscode-insiders/custom/vscode-custom.css"
  ],
  "workbench.colorTheme": "Calmppuccin Mocha",
  "workbench.iconTheme": "catppuccin-mocha",

  // zen (full screen settings):
  "zenMode.centerLayout": false,
  "zenMode.hideActivityBar": false,
  "zenMode.fullScreen": true,
  "zenMode.showTabs": "multiple",
  "zenMode.hideLineNumbers": false,
  "zenMode.silentNotifications": false,
  "zenMode.hideStatusBar": false,
  "calmppuccin.profiles": {
    "Default": {
      "fontStyleOverrides": {
        "mocha": {
          "commentFontStyle": "none",
          "typeFontStyle": "none",
          "typeAliasFontStyle": "none",
          "namespaceAttributeFontStyle": "none",
          "annotationFontStyle": "none",
          "directiveFontStyle": "none",
          "decoratorFontStyle": "none",
          "enumMemberFontStyle": "none",
          "propertyReadOnlyFontStyle": "none",
          "variableMutableFontStyle": "none",
          "extensionMethodFontStyle": "none",
          "delegateFontStyle": "none",
          "eventFontStyle": "none",
          "parameterFontStyle": "none",
          "stringVerbatimFontStyle": "none"
        }
      }
    }
  },
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "explorer.confirmDelete": false
}
